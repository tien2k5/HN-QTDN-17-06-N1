<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= Tree ================= -->

    <record id="view_cong_viec_tree" model="ir.ui.view">
        <field name="name">cong.viec.tree</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">

            <tree
                decoration-success="trang_thai == 'hoan_thanh'"
                decoration-warning="trang_thai == 'dang_thuc_hien'">

                <field name="ten_cong_viec"/>
                <field name="khach_hang_id"/>
                <field name="nhan_vien_id"/>
                <field name="han_hoan_thanh"/>
                <field name="tien_do"/>
                <field name="trang_thai"/>

            </tree>

        </field>
    </record>

    <!-- ================= Form ================= -->

    <record id="view_cong_viec_form" model="ir.ui.view">
        <field name="name">cong.viec.form</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <button
                        name="action_bat_dau"
                        string="Bắt đầu"
                        type="object"
                        class="btn-primary"
                        attrs="{'invisible':[('trang_thai','!=','moi')]}"/>

                    <button
                        name="action_hoan_thanh"
                        string="Hoàn thành"
                        type="object"
                        class="btn-success"
                        attrs="{'invisible':[('trang_thai','=','hoan_thanh')]}"/>

                    <field
                        name="trang_thai"
                        widget="statusbar"
                        statusbar_visible="moi,dang_thuc_hien,hoan_thanh"/>

                </header>

                <sheet>

                    <group>

                        <group>

                            <field name="ten_cong_viec"/>
                            <field name="khach_hang_id"/>
                            <field name="nhan_vien_id"/>
                            <field name="mo_ta"/>

                        </group>

                        <group>

                            <field name="ngay_tao"/>
                            <field name="han_hoan_thanh"/>
                            <field name="ngay_hoan_thanh" readonly="1"/>
                            <field name="tien_do" readonly="1"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>
    </record>

    <!-- ================= Action ================= -->

    <record id="action_cong_viec" model="ir.actions.act_window">
        <field name="name">Công việc</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ================= Menu ================= -->

    <menuitem
            id="menu_cong_viec_root"
            name="Quản lý công việc"/>

    <menuitem
            id="menu_cong_viec"
            name="Công việc"
            parent="menu_cong_viec_root"
            action="action_cong_viec"/>

</odoo>
